
/* 页面基础样式 */
.page.data-v-b0045dab {
  min-height: 100vh;
  background-color: #F8FAF9;
}

/* 顶部导航栏 - 浅青绿色渐变 */
.header-nav.data-v-b0045dab {
  position: relative;
  overflow: hidden;
}
.nav-bg.data-v-b0045dab {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 50%, #A5D6A7 100%);
}
.mountain-decoration.data-v-b0045dab {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, transparent 60%, rgba(255,255,255,0.4) 100%);
}
.nav-content.data-v-b0045dab {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 48px 16px 16px;
}
.back-btn.data-v-b0045dab {
  width: 36px;
  height: 36px;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  background-color: rgba(255,255,255,0.6);
  border-radius: 50%;
}
.back-icon.data-v-b0045dab {
  font-size: 18px;
  color: #2C3E50;
}
.nav-title.data-v-b0045dab {
  font-size: 18px;
  font-weight: 700;
  color: #2C3E50;
}
.nav-action.data-v-b0045dab {
  padding: 6px 12px;
  background-color: rgba(255,255,255,0.6);
  border-radius: 16px;
}
.nav-placeholder.data-v-b0045dab {
  width: 36px;
}

/* 搜索区域 */
.search-section.data-v-b0045dab {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 12px 16px;
  background: linear-gradient(180deg, #E8F5E9 0%, #F8FAF9 100%);
  gap: 12px;
}
.search-box.data-v-b0045dab {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 24px;
  padding: 0 16px;
  height: 40px;
  border: 1px solid #E8EDE9;
  transition: all 0.3s ease;
}
.search-box.is-focused.data-v-b0045dab {
  border-color: #5FB878;
  box-shadow: 0 2px 8px rgba(95,184,120,0.15);
}
.search-icon.data-v-b0045dab {
  font-size: 16px;
  color: #95A5A6;
  margin-right: 8px;
}
.search-input.data-v-b0045dab {
  flex: 1;
  height: 100%;
  font-size: 14px;
  color: #2C3E50;
}
.search-input.data-v-b0045dab::-webkit-input-placeholder {
  color: #B0BEC5;
}
.search-input.data-v-b0045dab::placeholder {
  color: #B0BEC5;
}
.search-clear.data-v-b0045dab {
  width: 20px;
  height: 20px;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  background-color: #E0E0E0;
  border-radius: 50%;
  margin-left: 8px;
}
.clear-icon.data-v-b0045dab {
  font-size: 14px;
  color: #FFFFFF;
  font-weight: 600;
}

/* 离线下载按钮 */
.download-btn.data-v-b0045dab {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  padding: 8px 12px;
  border-radius: 20px;
  border: 1px solid #A5D6A7;
  transition: all 0.2s ease;
  flex-shrink: 0;
}
.download-btn.data-v-b0045dab:active {
  transform: scale(0.95);
  background: linear-gradient(135deg, #C8E6C9 0%, #A5D6A7 100%);
}
.download-icon.data-v-b0045dab {
  font-size: 14px;
  margin-right: 4px;
}
.download-text.data-v-b0045dab {
  font-size: 12px;
  color: #2E7D32;
  font-weight: 500;
}

/* 地图区域 */
.map-container.data-v-b0045dab {
  position: relative;
  height: 280px;
  margin: 0 16px 16px;
  border-radius: 16px;
  overflow: hidden;
  background-color: #E8EDE9;
}
.map-image.data-v-b0045dab {
  width: 100%;
  height: 100%;
}
.map-marker.data-v-b0045dab {
  position: absolute;
  transform: translate(-50%, -50%);
  z-index: 10;
}
.marker-dot.data-v-b0045dab {
  width: 16px;
  height: 16px;
  background: linear-gradient(135deg, #5FB878 0%, #7EC8A6 100%);
  border-radius: 50%;
  border: 3px solid #FFFFFF;
  box-shadow: 0 2px 8px rgba(0,0,0,0.2);
}
.marker-pulse.data-v-b0045dab {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 30px;
  height: 30px;
  background-color: rgba(95,184,120,0.3);
  border-radius: 50%;
  animation: pulse-b0045dab 2s infinite;
}
@keyframes pulse-b0045dab {
0% {
    transform: translate(-50%, -50%) scale(1);
    opacity: 1;
}
100% {
    transform: translate(-50%, -50%) scale(2);
    opacity: 0;
}
}

/* 地图控制按钮 */
.map-controls.data-v-b0045dab {
  position: absolute;
  right: 12px;
  bottom: 12px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.control-btn.data-v-b0045dab {
  width: 40px;
  height: 40px;
  background-color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  transition: all 0.2s ease;
}
.control-btn.data-v-b0045dab:active {
  transform: scale(0.95);
  background-color: #F8FAF9;
}
.control-icon.data-v-b0045dab {
  font-size: 20px;
  color: #2C3E50;
  font-weight: 600;
}
.control-btn.locate .control-icon.data-v-b0045dab {
  font-size: 18px;
}

/* 地图缩放比例 */
.map-scale.data-v-b0045dab {
  position: absolute;
  left: 12px;
  bottom: 12px;
  background-color: rgba(0,0,0,0.6);
  padding: 4px 10px;
  border-radius: 12px;
}
.map-scale text.data-v-b0045dab {
  font-size: 12px;
  color: #FFFFFF;
  font-weight: 500;
}

/* 快捷服务栏 */
.facilities-section.data-v-b0045dab {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  padding: 16px;
  margin: 0 16px 12px;
  background-color: #FFFFFF;
  border-radius: 16px;
  border: 1px solid #E8EDE9;
}
.facility-item.data-v-b0045dab {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s ease;
}
.facility-item.data-v-b0045dab:active {
  transform: scale(0.95);
}
.facility-icon.data-v-b0045dab {
  width: 48px;
  height: 48px;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  margin-bottom: 8px;
}
.facility-icon.toilet.data-v-b0045dab {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
}
.facility-icon.restaurant.data-v-b0045dab {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
}
.facility-icon.medical.data-v-b0045dab {
  background: linear-gradient(135deg, #FFEBEE 0%, #FFCDD2 100%);
}
.facility-icon.parking.data-v-b0045dab {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}
.facility-icon.entrance.data-v-b0045dab {
  background: linear-gradient(135deg, #F3E5F5 0%, #E1BEE7 100%);
}
.facility-icon text.data-v-b0045dab {
  font-size: 22px;
}
.facility-name.data-v-b0045dab {
  font-size: 12px;
  color: #5D6D7E;
}

/* 离线提示栏 */
.offline-bar.data-v-b0045dab {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  margin: 0 16px 12px;
  background-color: #F5F5F5;
  border-radius: 12px;
  border: 1px solid #E0E0E0;
}
.offline-content.data-v-b0045dab {
  display: flex;
  flex-direction: row;
  align-items: center;
}
.offline-icon.data-v-b0045dab {
  font-size: 16px;
  margin-right: 8px;
}
.offline-text.data-v-b0045dab {
  font-size: 13px;
  color: #616161;
}
.offline-action.data-v-b0045dab {
  padding: 6px 12px;
  background-color: #FFFFFF;
  border-radius: 12px;
  border: 1px solid #BDBDBD;
}
.offline-action text.data-v-b0045dab {
  font-size: 12px;
  color: #616161;
  font-weight: 500;
}

/* 周边景点 */
.nearby-section.data-v-b0045dab {
  padding: 0 16px;
}
.section-header.data-v-b0045dab {
  display: flex;
