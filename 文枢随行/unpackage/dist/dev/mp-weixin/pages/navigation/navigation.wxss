}
.section-title.data-v-b0045dab {
  display: flex;
  flex-direction: row;
  align-items: center;
  font-size: 16px;
  font-weight: 700;
  color: #2C3E50;
}
.title-icon.data-v-b0045dab {
  font-size: 18px;
  margin-right: 6px;
}
.section-more.data-v-b0045dab {
  display: flex;
  flex-direction: row;
  align-items: center;
}
.section-more text.data-v-b0045dab {
