
/* 页面基础样式 */
.page.data-v-3a042aff {
  min-height: 100vh;
  background-color: #F8FAF9;
}

/* 顶部导航栏 */
.header-nav.data-v-3a042aff {
  position: relative;
  overflow: hidden;
}
.nav-bg.data-v-3a042aff {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 50%, #A5D6A7 100%);
}
.mountain-decoration.data-v-3a042aff {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, transparent 60%, rgba(255,255,255,0.4) 100%);
}
.nav-content.data-v-3a042aff {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 48px 16px 16px;
}
.nav-title.data-v-3a042aff {
  font-size: 20px;
  font-weight: 700;
  color: #2C3E50;
}
.nav-action.data-v-3a042aff {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: rgba(255,255,255,0.6);
  padding: 6px 12px;
  border-radius: 16px;
}
.action-icon.data-v-3a042aff {
  font-size: 18px;
  color: #27AE60;
  font-weight: 600;
}
.action-text.data-v-3a042aff {
  font-size: 11px;
  color: #27AE60;
  margin-top: 2px;
}

/* 行程列表 */
.trip-list.data-v-3a042aff {
  padding: 16px;
}

/* 空状态 */
.empty-state.data-v-3a042aff {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
}
.empty-icon.data-v-3a042aff {
  font-size: 64px;
  margin-bottom: 16px;
}
.empty-title.data-v-3a042aff {
  font-size: 18px;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 8px;
}
.empty-desc.data-v-3a042aff {
  font-size: 14px;
  color: #95A5A6;
  text-align: center;
  margin-bottom: 24px;
  line-height: 1.5;
}
.empty-btn.data-v-3a042aff {
  background: linear-gradient(135deg, #5FB878 0%, #7EC8A6 100%);
  padding: 14px 32px;
  border-radius: 24px;
}
.empty-btn text.data-v-3a042aff {
  font-size: 15px;
  color: #FFFFFF;
  font-weight: 600;
}

/* 左滑删除容器 */
.swipe-item.data-v-3a042aff {
  position: relative;
  margin-bottom: 16px;
}

/* 删除按钮 */
.delete-btn.data-v-3a042aff {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 80px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #E74C3C;
  border-radius: 0 16px 16px 0;
}
.delete-icon.data-v-3a042aff {
  font-size: 20px;
  margin-bottom: 4px;
}
.delete-text.data-v-3a042aff {
  font-size: 13px;
  color: #FFFFFF;
  font-weight: 500;
}

/* 行程卡片 */
.trip-card.data-v-3a042aff {
  position: relative;
  border-radius: 16px;
  overflow: hidden;
  background-color: #FFFFFF;
  border: 1px solid #E8EDE9;
  transition: transform 0.3s ease;
}
.card-bg.data-v-3a042aff {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(90deg, #5FB878 0%, #7EC8A6 100%);
}
.card-content.data-v-3a042aff {
  padding: 20px 16px 16px;
}
.trip-header.data-v-3a042aff {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}
.trip-title.data-v-3a042aff {
  font-size: 17px;
  font-weight: 700;
  color: #2C3E50;
}
.trip-status.data-v-3a042aff {
  font-size: 11px;
  padding: 4px 10px;
  border-radius: 12px;
}
.trip-status.confirmed.data-v-3a042aff {
  color: #5FB878;
  background-color: #E8F5E9;
}
.trip-status.pending.data-v-3a042aff {
  color: #FF9A56;
  background-color: #FFF3E0;
}
.trip-info.data-v-3a042aff {
  display: flex;
  flex-direction: row;
  margin-bottom: 16px;
}
.info-item.data-v-3a042aff {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-right: 20px;
}
.info-icon.data-v-3a042aff {
  font-size: 14px;
  margin-right: 4px;
}
.info-text.data-v-3a042aff {
  font-size: 13px;
  color: #5D6D7E;
}
.trip-footer.data-v-3a042aff {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding-top: 12px;
  border-top: 1px solid #F0F0F0;
}
.create-time.data-v-3a042aff {
  font-size: 12px;
  color: #95A5A6;
}
.arrow-icon.data-v-3a042aff {
  font-size: 16px;
  color: #5FB878;
  font-weight: 600;
}

/* 底部留白 */
.bottom-space.data-v-3a042aff {
  height: 30px;
}
